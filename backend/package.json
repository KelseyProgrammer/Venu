    "@types/socket.io": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "express-session": "^1.18.2",
    "firebase-admin": "^13.5.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.1.0",
    "mongoose": "^8.17.1",
    "multer": "^2.0.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^21.0.1",
    "url": "^0.11.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
