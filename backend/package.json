    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.1.0",
    "mongoose": "^8.17.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "url": "^0.11.4",
    "zod": "^3.22.4"
