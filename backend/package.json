  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "PORT=3001 nodemon -e ts,js --watch src --exec \"tsx src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "postinstall": "",
    "validate": "npm run type-check && npm run lint && npm run build",
    "migrate:notifications": "tsx src/scripts/migrate-notifications.ts",
    "migrate:fcm-tokens": "tsx src/scripts/manage-fcm-tokens.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
